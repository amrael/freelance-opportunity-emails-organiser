# foe - Freelance Opportunity Emails configuration

# ── Ollama (local LLM, used as fallback) ──
OLLAMA_URL=http://localhost:11434
FOE_MODEL=gemma3:4b

# ── LLM extraction backend: "bedrock" (default) or "ollama" ──
FOE_EXTRACTOR=bedrock
FOE_BEDROCK_MODEL=qwen.qwen3-235b-a22b-2507-v1:0

# ── AWS (required if FOE_EXTRACTOR=bedrock) ──
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Agent domains (comma-separated) ──
# Emails from these domains are treated as agent/recruiter emails.
# Defaults are built into the code; override here to add more.
FOE_AGENT_DOMAINS=linkedin.com,example-agency.co.jp

# ── User profile (used for AI fit scoring) ──
FOE_USER_NAME=Your Name
FOE_USER_PROFILE=- Role: Freelance CTO\n- Strengths: ...\n- Target pay: ...

# ── Obsidian export path (optional) ──
FOE_EXPORT_PATH=~/obsidian-vault/Freelance/pipeline.md
